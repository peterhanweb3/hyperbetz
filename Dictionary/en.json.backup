	"terms": {
		"title": "Terms & Conditions",
		"subtitle": "User Agreement and Platform Rules",
		"lastUpdated": "January 2025",
		"intro": {
			"paragraph1": "By registering or connecting your wallet on www.{siteName}, you enter into a binding agreement with {siteName} N.V.",
