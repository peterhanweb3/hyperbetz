	"privacy": {
		"title": "Privacy Policy",
		"subtitle": "How {siteName} collects, uses, and protects your data",
		"lastUpdated": "January 2025",
		"intro": {
			"paragraph1": "{siteName} ('{siteName}', 'we', 'us', or 'our') runs the {siteName} crypto-casino platform. This Privacy Policy explains how we collect, use, store and protect personal and transaction data when you use our website, mobile apps, or related services (the 'Services').",
			"paragraph2": "{siteName} operates as a crypto-wallet-only casino: all deposits and withdrawals are made using cryptocurrency wallets. We are committed to protecting your privacy while meeting regulatory obligations (such as AML/KYC requirements) and ensuring a safe, fair gaming environment.",
			"paragraph3": "By accessing or using {siteName} you accept the terms of this Privacy Policy."
		},
		"sections": {
			"scope": {
				"title": "1. Scope & Acceptance",
				"content": "This policy applies to all users of {siteName}. We may update this policy; updates take effect when posted on the site. Continued use following a change means you accept the new policy."
			},
			"dataCollection": {
				"title": "2. What Data We Collect",
				"intro": "Because we operate with crypto wallets only, the types of data we collect reflect that model. We collect:",
				"accountData": {
					"title": "A. Account & Identity Data (when required)",
					"email": "Email (if provided), display name, account ID.",
					"kyc": "Important: While crypto wallets enable on-chain anonymity, certain transactions or regulatory triggers may require identity verification. We will clearly request KYC only when necessary."
				},
				"walletData": {
					"title": "B. Wallet & Transaction Data",
					"addresses": "Cryptocurrency wallet addresses you connect or use with {siteName}.",
					"transactions": "On-chain transaction hashes and timestamps (deposits/withdrawals).",
					"metadata": "Transaction metadata necessary to reconcile payments and prevent fraud."
				},
				"technicalData": {
					"title": "C. Technical & Usage Data",
					"ip": "IP address, approximate geolocation derived from IP, device type, browser, OS.",
					"session": "Session logs, time stamps, pages visited, game activity, wagers and outcomes.",
					"cookies": "Cookies and analytics data to improve site performance and user experience."
				},
				"securityData": {
					"title": "D. Security & Risk Data",
					"fraud": "Fraud signals, device fingerprints, risk scores from anti-fraud vendors.",
					"disputes": "Records of dispute resolution, chargebacks (if applicable), and compliance checks."
				}
			},
			"purposes": {
				"title": "3. Why We Collect Data ‚Äì Lawful Bases & Purposes",
				"items": {
					"0": {
						"title": "Service provision & contract performance",
						"description": "to create and maintain accounts, process deposits/withdrawals via crypto wallets, pay winnings."
					},
					"1": {
						"title": "Security & fraud prevention",
						"description": "detect and prevent abuse and money-laundering."
					},
					"2": {
						"title": "Compliance with legal obligations",
						"description": "meet AML/KYC requirements when necessary."
					},
					"3": {
						"title": "Platform operations & improvement",
						"description": "analytics, product development, customer support."
					},
					"4": {
						"title": "Marketing (with consent)",
						"description": "newsletters, promotional offers ‚Äî only if you opt in."
					},
					"5": {
						"title": "Legitimate interest",
						"description": "preserving platform integrity and investigating misuse."
					}
				}
			},
			"cryptoWallet": {
				"title": "4. Crypto Wallet Specifics & On-Chain Data",
				"points": {
					"0": "Wallet addresses and on-chain transaction data are stored only to the extent necessary to credit/debit user accounts, audit transactions, and meet compliance obligations.",
					"1": "On-chain data is public by nature ‚Äî {siteName} does not control blockchain visibility. We combine on-chain data with off-chain records to reconcile accounts.",
					"2": "If you connect a custodial wallet service (third-party), you consent to any data those providers share with us for transaction processing."
				}
			},
			"dataSharing": {
				"title": "5. When We Share Data",
				"intro": "We may share your information:",
				"items": {
					"0": "With regulators or law enforcement when compelled by legal process or to prevent illegal activity.",
					"1": "With affiliates or third parties in a business transfer (merger, acquisition) ‚Äî always with appropriate safeguards.",
					"2": "With fraud prevention networks to protect our platform and users."
				},
				"noSelling": "We do not sell your personal data to advertisers."
			},
			"security": {
				"title": "6. Security Measures",
				"intro": "We use industry-standard security measures:",
				"items": {
					"0": "TLS/SSL encryption in transit; encrypted storage for sensitive data.",
					"1": "Access controls, logging, and role-based privileges.",
					"2": "Regular security audits and vulnerability testing.",
					"3": "Multi-factor authentication (MFA) for staff and optional for users."
				},
				"warning": "You must keep your wallet private keys and account credentials secure. We never request private keys."
			},
			"cookies": {
				"title": "7. Cookies & Tracking",
				"content": "We use cookies and similar technologies for necessary site functions, analytics, and (with consent) marketing. You can control cookies in your browser, but disabling essential cookies may break functionality."
